{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Sylphx org-wide Renovate preset (Doctrine ADR-6). Updates land through merge queues: PR goes green, auto-merge enqueues, the queue validates and merges. Non-major updates are fully unattended; majors wait for an agent.",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits",
    ":enableVulnerabilityAlerts",
    "group:monorepos",
    "group:recommended"
  ],
  "timezone": "Asia/Hong_Kong",
  "schedule": ["after 10pm", "before 6am"],
  "dependencyDashboardTitle": "Dependency Dashboard",
  "labels": ["dependencies"],
  "rebaseWhen": "conflicted",
  "platformAutomerge": true,
  "prConcurrentLimit": 8,
  "prHourlyLimit": 4,
  "minimumReleaseAge": "3 days",
  "osvVulnerabilityAlerts": true,
  "vulnerabilityAlerts": {
    "schedule": ["at any time"],
    "minimumReleaseAge": null,
    "labels": ["security"]
  },
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true,
    "schedule": ["before 6am on monday"]
  },
  "packageRules": [
    {
      "description": "Non-major updates merge unattended through the queue",
      "matchUpdateTypes": ["minor", "patch", "digest", "pin", "pinDigest"],
      "automerge": true
    },
    {
      "description": "Majors need an agent decision; keep them visible and rare",
      "matchUpdateTypes": ["major"],
      "labels": ["dependencies", "breaking"],
      "minimumReleaseAge": "7 days"
    },
    {
      "description": "Type definitions are safe to batch and merge",
      "matchPackageNames": ["@types/{/,}**"],
      "groupName": "TypeScript type definitions",
      "automerge": true
    },
    {
      "description": "Pin GitHub Action digests for supply-chain integrity",
      "matchManagers": ["github-actions"],
      "pinDigests": true
    },
    {
      "matchDatasources": ["docker"],
      "labels": ["docker-update"]
    },
    {
      "matchManagers": ["gradle", "gradle-wrapper"],
      "groupName": "android dependencies",
      "labels": ["android"]
    },
    {
      "matchPackageNames": ["com.android.**", "androidx.**", "com.google.android.**"],
      "groupName": "android core dependencies",
      "minimumReleaseAge": "7 days"
    },
    {
      "matchDatasources": ["swift", "pod"],
      "groupName": "iOS dependencies",
      "labels": ["ios"],
      "minimumReleaseAge": "5 days"
    },
    {
      "matchDatasources": ["dart", "pub"],
      "groupName": "Flutter dependencies",
      "labels": ["flutter", "dart"]
    },
    {
      "description": "Effect ecosystem moves in lockstep",
      "matchPackageNames": ["effect", "@effect/**"],
      "groupName": "Effect packages",
      "labels": ["effect"]
    },
    {
      "matchPackageNames": ["react", "react-*", "@react/**", "@types/react*"],
      "groupName": "React packages",
      "labels": ["react"]
    },
    {
      "matchPackageNames": ["/biome/", "/eslint/", "/prettier/"],
      "groupName": "Linting packages",
      "labels": ["linting"]
    },
    {
      "matchPackageNames": ["bun", "@types/bun", "bun-types"],
      "groupName": "Bun runtime",
      "labels": ["bun"]
    },
    {
      "matchDatasources": ["packagist"],
      "labels": ["php"]
    },
    {
      "matchManagers": [
        "pip_requirements",
        "pip_setup",
        "pipenv",
        "poetry",
        "pep621"
      ],
      "groupName": "Python dependencies",
      "labels": ["python"]
    }
  ],
  "docker": {
    "pinDigests": true
  },
  "ignorePaths": [
    "**/ios/Pods/**",
    "**/android/.gradle/**",
    "**/node_modules/**",
    "**/vendor/**",
    "**/.cache/**",
    "**/dist/**",
    "**/build/**"
  ]
}
